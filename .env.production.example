# ============================================================
# Sardoba PMS — Production Environment Variables
# Copy to .env and fill in real values
# ============================================================

NODE_ENV=production
PORT=3001
APP_URL=https://api.sardoba.uz
FRONTEND_URL=https://app.sardoba.uz

# --- Database (managed PostgreSQL — Railway / Supabase / Neon) ---
DATABASE_URL=postgresql://user:password@host:5432/sardoba_prod?sslmode=require
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# --- Redis (managed — Railway / Upstash) ---
REDIS_URL=redis://default:password@host:6379
REDIS_PASSWORD=your_redis_password

# --- JWT (generate with: openssl rand -hex 32) ---
JWT_SECRET=<min-32-chars-random-string>
JWT_EXPIRES_IN=86400
JWT_REFRESH_SECRET=<min-32-chars-random-string>
JWT_REFRESH_EXPIRES_IN=604800

# --- Encryption (for passport data) ---
ENCRYPTION_KEY=<32-byte-hex-string>

# --- Cloudinary (room photos) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_BOT_WEBHOOK_SECRET=your_webhook_secret

# --- Payme ---
PAYME_MERCHANT_ID=your_merchant_id
PAYME_SECRET_KEY=your_secret_key
PAYME_CHECKOUT_URL=https://checkout.paycom.uz

# --- Click ---
CLICK_MERCHANT_ID=your_merchant_id
CLICK_SERVICE_ID=your_service_id
CLICK_SECRET_KEY=your_secret_key

# --- Booking.com Channel Manager ---
BOOKING_API_KEY=your_api_key
BOOKING_HOTEL_ID=your_hotel_id
BOOKING_WEBHOOK_SECRET=your_webhook_secret

# --- Sentry (error tracking) ---
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# --- Email (Resend) ---
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=noreply@sardoba.uz

# --- WhatsApp Business API ---
WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_TOKEN=your_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_id

# --- Widget / Public Booking ---
WIDGET_URL=https://app.sardoba.uz/book
NEXT_PUBLIC_WIDGET_URL=https://app.sardoba.uz/book
WIDGET_RATE_LIMIT=10

# --- Web Push / VAPID ---
VAPID_PUBLIC_KEY=<generate-with-web-push>
VAPID_PRIVATE_KEY=<generate-with-web-push>
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<same-as-VAPID_PUBLIC_KEY>

# --- Feature Flags ---
FEATURE_CHANNEL_MANAGER=true
FEATURE_ONLINE_PAYMENTS=true
FEATURE_ANALYTICS=true

# --- Next.js (Web app) ---
NEXT_PUBLIC_API_URL=https://api.sardoba.uz/v1
